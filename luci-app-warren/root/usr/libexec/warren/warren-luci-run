#!/bin/sh

mode="$1"
[ -n "$mode" ] || {
  echo "Usage: warren-luci-run <mode>" >&2
  exit 2
}

job="/tmp/warren-luci-job"
log="${job}.log"
pidfile="${job}.pid"
form_env="${job}.env"

if [ -s "$pidfile" ] && kill -0 "$(cat "$pidfile" 2>/dev/null)" 2>/dev/null; then
  echo "Warren job is already running: $(cat "$pidfile")"
  exit 0
fi

(
  echo "$$" > "$pidfile"
  {
    echo "=== Warren LuCI job: $mode ==="
    date
    echo
    if [ -r "$form_env" ]; then
      # shellcheck disable=SC1090
      . "$form_env"
    fi
    WARREN_LUCI=1 WARREN_USE_LOCAL_LIBS=1 WARREN_BASE_DIR=/etc WARREN_LOG_DIR=/root /usr/bin/warren --luci-run "$mode"
    rc=$?
    echo
    echo "=== exit code: $rc ==="
    date
    rm -f "$pidfile"
    exit "$rc"
  } > "$log" 2>&1
) &

echo "Started Warren job: $mode"
